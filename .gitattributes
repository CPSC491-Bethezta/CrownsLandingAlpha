# Make the repo store text files as LF
* text=auto eol=lf
# Unity / code
*.cs     text eol=lf
*.shader text eol=lf
*.cginc  text eol=lf
*.hlsl   text eol=lf
*.compute text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.meta   text eol=lf
*.unity  text eol=lf
*.prefab text eol=lf
*.asmdef text eol=lf
# Binary assets (never normalize)
*.png binary
*.jpg binary
*.jpeg binary
*.tga binary
*.fbx binary
*.wav binary
*.mp3 binary
*.ogg binary
*.asset filter=lfs diff=lfs merge=lfs -text
